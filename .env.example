# Copy this file to .env and fill in your IFB220 Developer API Portal values.

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Deployment/model names from the IFB220 Developer API Portal.
CHAT_DEPLOYMENT_NAME=gpt-4.1-mini
EMBEDDING_DEPLOYMENT_NAME=ada-002

# Assignment topic. Change this to reuse the chatbot for another topic.
ALLOWED_TOPIC=gardening

# Guardrail tuning. Increase threshold for stricter topic matching.
SIMILARITY_THRESHOLD=0.72
MAX_HISTORY_MESSAGES=8
